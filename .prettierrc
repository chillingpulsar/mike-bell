{
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "none",
	"printWidth": 100,
	"plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
	"overrides": [
		{
			"files": "*.svelte",
			"options": {
				"parser": "svelte"
			}
		},
		{
			"files": "app/**",
			"options": {
				"tailwindStylesheet": "./app/src/routes/layout.css"
			}
		},
		{
			"files": "web/**",
			"options": {
				"tailwindStylesheet": "./web/src/routes/layout.css"
			}
		}
	]
}
